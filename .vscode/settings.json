{
    "cSpell.language": "ca,en",
    "cSpell.words": [
        "ANOVA",
        "Bioconductor",
        "dplyr",
        "Epith",
        "ggplot",
        "heterocedasticitat",
        "homcedasticitat",
        "kable",
        "knitr",
        "lapply",
        "mlbench",
        "newpage",
        "nrow",
        "pvalue",
        "sapply",
        "tidyverse",
        "Tukey",
        "usepackage",
        "virginica",
        "xelatex"
    ],
    "editor.codeActionsOnSave": {
        "source.fixAll.markdownlint": "always"
    },
    "editor.formatOnSave": true,
    "editor.rulers": [
        80
    ],
    "[markdown]": {
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
        "editor.formatOnPaste": true
    },
    "[rmd]": {
        "editor.formatOnSave": true
    },
    "r.helpPanel.cacheIndexFiles": "Workspace",
    "r.alwaysUseActiveTerminal": true,
    "r.rpath.mac": "${workspaceFolder}/.conda/bin/R",
    "r.lsp.lang": "en_US.UTF-8",
    "r.lsp.use_stdio": true,
}